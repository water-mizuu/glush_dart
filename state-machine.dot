digraph StateMachine {
  rankdir=LR;
  node [fontname="Courier"];
  "__start__" [shape=point, label=""];
  "__accept__" [shape=doublecircle, label="accept"];
  "__return_rul:S0:__" [shape=box, label="return rul:S0:", style=filled, fillcolor=lightgray];
  "S0" [shape=circle, label="init"];
  "S1" [shape=doublecircle, label="<S_0>"];
  "S2" [shape=circle, label="<S>"];
  "S3" [shape=circle, label="label_start(S.2)"];
  "S4" [shape=circle, label="label_start(S.1)"];
  "S5" [shape=circle, label="<S_1>"];
  "S6" [shape=circle, label="<S_2>"];
  "S7" [shape=circle, label="label_end(S.2)"];
  "S8" [shape=circle, label="s"];
  "S9" [shape=circle, label="label_end(S.1)"];
  "__start__" -> "S0" [label="start"];
  "S0" -> "S1" [label="call rul:S0:", style=bold];
  "S1" -> "__accept__" [label="accept"];
  "S2" -> "S3" [label="label start S.2"];
  "S2" -> "S4" [label="label start S.1"];
  "S3" -> "S5" [label="call rul:S0:", style=bold];
  "S4" -> "S8" [label="token s"];
  "S5" -> "S6" [label="call rul:S0:", style=bold];
  "S6" -> "S7" [label="label end S.2"];
  "S7" -> "__return_rul:S0:__" [label="return rul:S0:", style=dashed, color=gray45];
  "S8" -> "S9" [label="label end S.1"];
  "S9" -> "__return_rul:S0:__" [label="return rul:S0:", style=dashed, color=gray45];
}

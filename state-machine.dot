digraph StateMachine {
  rankdir=LR;
  node [fontname="Courier"];
  "__start__" [shape=point, label=""];
  "__accept__" [shape=doublecircle, label="accept"];
  "__return_S__" [shape=box, label="return S", style=filled, fillcolor=lightgray];
  "S0" [shape=circle, label="init"];
  "S1" [shape=doublecircle, label="<S_0>"];
  "S2" [shape=circle, label="<S>"];
  "S3" [shape=circle, label="label_start(S.2)"];
  "S4" [shape=circle, label="s"];
  "S5" [shape=circle, label="and(<S_1>)"];
  "S6" [shape=circle, label="s"];
  "S7" [shape=circle, label="label_end(S.2)"];
  "__start__" -> "S0" [label="start"];
  "S0" -> "S1" [label="call S", style=bold];
  "S1" -> "__accept__" [label="accept"];
  "S2" -> "S3" [label="label start S.2"];
  "S2" -> "S4" [label="token s"];
  "S3" -> "S5" [label="AND rul:S0:", style=dashed, color=seagreen4];
  "S4" -> "__return_S__" [label="return S", style=dashed, color=gray45];
  "S5" -> "S6" [label="token s"];
  "S6" -> "S7" [label="label end S.2"];
  "S7" -> "__return_S__" [label="return S", style=dashed, color=gray45];
}

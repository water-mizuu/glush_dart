digraph StateMachine {
  rankdir=LR;
  node [fontname="Courier"];
  "__start__" [shape=point, label=""];
  "__accept__" [shape=doublecircle, label="accept"];
  "__return_0__" [shape=box, label="return 0", style=filled, fillcolor=lightgray];
  "S0" [shape=circle, label="init"];
  "S1" [shape=doublecircle, label="<S_0>"];
  "S2" [shape=circle, label="<S>"];
  "S3" [shape=circle, label="48..57"];
  "S4" [shape=circle, label="48..57"];
  "__start__" -> "S0" [label="start"];
  "S0" -> "S1" [label="call 0", style=bold];
  "S1" -> "__accept__" [label="accept"];
  "S2" -> "S3" [label="token 48..57"];
  "S3" -> "S3" [label="token 48..57"];
  "S3" -> "S4" [label="token 48..57"];
  "S4" -> "__return_0__" [label="return S", style=dashed, color=gray45];
}

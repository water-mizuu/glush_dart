digraph StateMachine {
  rankdir=LR;
  node [fontname="Courier"];
  "__start__" [shape=point, label=""];
  "__accept__" [shape=doublecircle, label="accept"];
  "__return_rul:S0:__" [shape=box, label="return rul:S0:", style=filled, fillcolor=lightgray];
  "__return_rul:S21:__" [shape=box, label="return rul:S21:", style=filled, fillcolor=lightgray];
  "__return_rul:S27:__" [shape=box, label="return rul:S27:", style=filled, fillcolor=lightgray];
  "S0" [shape=circle, label="init"];
  "S1" [shape=doublecircle, label="<S_0>"];
  "S2" [shape=circle, label="<S>"];
  "S3" [shape=circle, label="label_start(S.3)"];
  "S4" [shape=circle, label="label_start(S.2)"];
  "S5" [shape=circle, label="label_start(S.1)"];
  "S6" [shape=circle, label="and(<pred$0_0>)"];
  "S7" [shape=circle, label="<S_4>"];
  "S8" [shape=circle, label="<S_5>"];
  "S9" [shape=circle, label="<S_6>"];
  "S10" [shape=circle, label="label_end(S.3)"];
  "S11" [shape=circle, label="and(<pred$1_0>)"];
  "S12" [shape=circle, label="<S_9>"];
  "S13" [shape=circle, label="<S_10>"];
  "S14" [shape=circle, label="label_end(S.2)"];
  "S15" [shape=circle, label="s"];
  "S16" [shape=circle, label="label_end(S.1)"];
  "S17" [shape=circle, label="<pred$0>"];
  "S18" [shape=circle, label="<S_1>"];
  "S19" [shape=circle, label="<S_2>"];
  "S20" [shape=circle, label="<S_3>"];
  "S21" [shape=circle, label="<pred$1>"];
  "S22" [shape=circle, label="<S_7>"];
  "S23" [shape=circle, label="<S_8>"];
  "__start__" -> "S0" [label="start"];
  "S0" -> "S1" [label="call rul:S0:", style=bold];
  "S1" -> "__accept__" [label="accept"];
  "S2" -> "S3" [label="label start S.3"];
  "S2" -> "S4" [label="label start S.2"];
  "S2" -> "S5" [label="label start S.1"];
  "S3" -> "S6" [label="AND rul:S21:", style=dashed, color=seagreen4];
  "S4" -> "S11" [label="AND rul:S27:", style=dashed, color=seagreen4];
  "S5" -> "S15" [label="token s"];
  "S6" -> "S7" [label="call rul:S0:", style=bold];
  "S7" -> "S8" [label="call rul:S0:", style=bold];
  "S8" -> "S9" [label="call rul:S0:", style=bold];
  "S9" -> "S10" [label="label end S.3"];
  "S10" -> "__return_rul:S0:__" [label="return rul:S0:", style=dashed, color=gray45];
  "S11" -> "S12" [label="call rul:S0:", style=bold];
  "S12" -> "S13" [label="call rul:S0:", style=bold];
  "S13" -> "S14" [label="label end S.2"];
  "S14" -> "__return_rul:S0:__" [label="return rul:S0:", style=dashed, color=gray45];
  "S15" -> "S16" [label="label end S.1"];
  "S16" -> "__return_rul:S0:__" [label="return rul:S0:", style=dashed, color=gray45];
  "S17" -> "S18" [label="call rul:S0:", style=bold];
  "S18" -> "S19" [label="call rul:S0:", style=bold];
  "S19" -> "S20" [label="call rul:S0:", style=bold];
  "S20" -> "__return_rul:S21:__" [label="return rul:S21:", style=dashed, color=gray45];
  "S21" -> "S22" [label="call rul:S0:", style=bold];
  "S22" -> "S23" [label="call rul:S0:", style=bold];
  "S23" -> "__return_rul:S27:__" [label="return rul:S27:", style=dashed, color=gray45];
}

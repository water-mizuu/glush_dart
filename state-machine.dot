digraph StateMachine {
  rankdir=LR;
  node [fontname="Courier"];
  "__start__" [shape=point, label=""];
  "__accept__" [shape=doublecircle, label="accept"];
  "__return_0__" [shape=box, label="return 0", style=filled, fillcolor=lightgray];
  "__return_4__" [shape=box, label="return 4", style=filled, fillcolor=lightgray];
  "S0" [shape=doublecircle, label="init"];
  "S1" [shape=doublecircle, label="<_0>"];
  "S2" [shape=circle, label="<>"];
  "S3" [shape=circle, label="neg(<neg$0_0>)"];
  "S4" [shape=circle, label="<neg$0>"];
  "S5" [shape=circle, label="48..57"];
  "__start__" -> "S0" [label="start"];
  "S0" -> "S1" [label="call 0", style=bold];
  "S0" -> "__accept__" [label="accept"];
  "S1" -> "__accept__" [label="accept"];
  "S2" -> "S3" [label="Neg 4"];
  "S2" -> "__return_0__" [label="return ", style=dashed, color=gray45];
  "S3" -> "S3" [label="Neg 4"];
  "S3" -> "__return_0__" [label="return ", style=dashed, color=gray45];
  "S4" -> "S5" [label="token 48..57"];
  "S5" -> "__return_4__" [label="return neg$0", style=dashed, color=gray45];
}

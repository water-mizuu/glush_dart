digraph StateMachine {
  rankdir=LR;
  node [fontname="Courier"];
  "__start__" [shape=point, label=""];
  "__accept__" [shape=doublecircle, label="accept"];
  "__return_test__" [shape=box, label="return test", style=filled, fillcolor=lightgray];
  "__return_a__" [shape=box, label="return a", style=filled, fillcolor=lightgray];
  "__return_pred$0__" [shape=box, label="return pred$0", style=filled, fillcolor=lightgray];
  "S0" [shape=circle, label="init"];
  "S1" [shape=doublecircle, label="<test_0>"];
  "S2" [shape=circle, label="<test>"];
  "S3" [shape=circle, label="not(<pred$0_0>)"];
  "S4" [shape=circle, label="b"];
  "S5" [shape=circle, label="<a>"];
  "S6" [shape=circle, label="a"];
  "S7" [shape=circle, label="<pred$0>"];
  "S8" [shape=circle, label="<a_0>"];
  "S9" [shape=circle, label="<a_1>"];
  "__start__" -> "S0" [label="start"];
  "S0" -> "S1" [label="call test", style=bold];
  "S1" -> "__accept__" [label="accept"];
  "S2" -> "S3" [label="NOT rul:S7:", style=dashed, color=seagreen4];
  "S3" -> "S4" [label="token b"];
  "S4" -> "__return_test__" [label="return test", style=dashed, color=gray45];
  "S5" -> "S6" [label="token a"];
  "S6" -> "__return_a__" [label="return a", style=dashed, color=gray45];
  "S7" -> "S8" [label="call a", style=bold];
  "S7" -> "S9" [label="call a", style=bold];
  "S8" -> "__return_pred$0__" [label="return pred$0", style=dashed, color=gray45];
  "S9" -> "__return_pred$0__" [label="return pred$0", style=dashed, color=gray45];
}
